# Application
APP_NAME=OneDocs Auth Service
APP_VERSION=1.0.0
DEBUG=True

# Database
# For local development: use 'localhost'
# For Docker Compose: use 'postgres'
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=onedocs_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=onedocs_auth
DATABASE_URL=postgresql+asyncpg://onedocs_user:your_secure_password_here@localhost:5432/onedocs_auth

# JWT
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-min-32-characters-long-change-this
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,https://frontend-preprod.onedocs.ai

# Server
HOST=0.0.0.0
PORT=8001

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30
PASSWORD_RESET_RATE_LIMIT_REQUESTS=3
PASSWORD_RESET_RATE_LIMIT_WINDOW_HOURS=1
FRONTEND_RESET_PASSWORD_URL=http://app.onedocs.ai/reset-password

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@onedocs.com
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5051

# Progressive login brute-force gate. Defaults match production policy
# (3 fail/15min → CAPTCHA, 6 fail/1h → 15min cooldown, 10 fail/24h → 24h lock).
# Override only for local testing — leave unset in production .env.
# LOGIN_GATE_CAPTCHA_THRESHOLD=3
# LOGIN_GATE_COOLDOWN_THRESHOLD=6
# LOGIN_GATE_LOCK_THRESHOLD=10
# LOGIN_GATE_CAPTCHA_WINDOW_MINUTES=15
# LOGIN_GATE_COOLDOWN_WINDOW_MINUTES=60
# LOGIN_GATE_LOCK_WINDOW_HOURS=24
# LOGIN_GATE_COOLDOWN_DURATION_MINUTES=15
# LOGIN_GATE_LOCK_DURATION_HOURS=24

# Cloudflare Turnstile (CAPTCHA). Secret key from
# https://dash.cloudflare.com → Turnstile → site → "Secret key".
# In local dev with no real key, set TURNSTILE_ALWAYS_PASS=true to accept
# any non-empty token. NEVER set TURNSTILE_ALWAYS_PASS in preprod/prod.
TURNSTILE_SECRET_KEY=
TURNSTILE_ALWAYS_PASS=true

# Test-only bypass for /login progressive gate. When the request carries
# X-Test-Secret with this value, the gate evaluation is skipped (failures
# are still logged for visibility). Leave empty in any non-test
# environment — fail-closed when unset.
TEST_BYPASS_SECRET=